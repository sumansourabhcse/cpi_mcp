                </ifl:property>
                <ifl:property>
                    <key>urlPath</key>
                    <value>/http-to-soap</value>
                </ifl:property>
                <ifl:property>
                    <key>httpMethod</key>
                    <value>POST</value>
                </ifl:property>
                <ifl:property>
                    <key>ComponentType</key>
                    <value>HTTP</value>
                </ifl:property>
                <ifl:property>
                    <key>Name</key>
                    <value>HTTP</value>
                </ifl:property>
                <ifl:property>

                </bpmn2:extensionElements>
                <bpmn2:incoming>SequenceFlow_Exception_1</bpmn2:incoming>
                <bpmn2:outgoing>SequenceFlow_Exception_2</bpmn2:outgoing>
            </bpmn2:scriptTask>
            <bpmn2:callActivity id="ContentModifier_Error" name="Set Error Response">
                <bpmn2:extensionElements>
                    <ifl:property>
                        <key>activityType</key>
                        <value>Enricher</value>
                    </ifl:property>
                    <ifl:property>
                        <key>componentVersion</key>
                        <value>1.2</value>
                    </ifl:property>
                    <ifl:property>
                        <key>headerTable</key>
                        <value>&lt;row&gt;&lt;cell&gt;CamelHttpResponseCode&lt;/cell&gt;&lt;cell&gt;500&lt;/cell&gt;&lt;cell&gt;constant&lt;/cell&gt;&lt;cell&gt;false&lt;/cell&gt;&lt;cell&gt;false&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;Content-Type&lt;/cell&gt;&lt;cell&gt;application/json&lt;/cell&gt;&lt;cell&gt;constant&lt;/cell&gt;&lt;cell&gt;false&lt;/cell&gt;&lt;cell&gt;false&lt;/cell&gt;&lt;/row&gt;</value>
                    </ifl:property>
                    <ifl:property>
                        <key>bodyType</key>
                        <value>expression</value>
                    </ifl:property>
                    <ifl:property>
                        <key>Name</key>
                        <value>ContentModifier</value>
                    </ifl:property>
                    <ifl:property>
                        <key>TransportProtocolVersion</key>
                        <value>1.2.0</value>
                    </ifl:property>
                </bpmn2:extensionElements>
                <bpmn2:incoming>SequenceFlow_Exception_2</bpmn2:incoming>
                <bpmn2:outgoing>SequenceFlow_Exception_3</bpmn2:outgoing>
            </bpmn2:callActivity>
            <bpmn2:endEvent id="EndEvent_Exception" name="Error End">
                <bpmn2:extensionElements>
                    <ifl:property>
                        <key>componentVersion</key>
                        <value>1.0</value>
                    </ifl:property>
                </bpmn2:extensionElements>
                <bpmn2:incoming>SequenceFlow_Exception_3</bpmn2:incoming>
                <bpmn2:messageEventDefinition/>
            </bpmn2:endEvent>
            <bpmn2:sequenceFlow id="SequenceFlow_Exception_1" sourceRef="StartEvent_Exception" targetRef="ScriptTask_LogError"/>
            <bpmn2:sequenceFlow id="SequenceFlow_Exception_2" sourceRef="ScriptTask_LogError" targetRef="ContentModifier_Error"/>
            <bpmn2:sequenceFlow id="SequenceFlow_Exception_3" sourceRef="ContentModifier_Error" targetRef="EndEvent_Exception"/>
        </bpmn2:subProcess>
    </bpmn2:process>

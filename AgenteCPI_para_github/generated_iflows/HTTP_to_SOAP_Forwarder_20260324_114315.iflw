                    <key>ifl:type</key>
                    <value>EndpointRecevier</value>
                </ifl:property>
            </bpmn2:extensionElements>
        </bpmn2:participant>
        <bpmn2:participant id="Participant_Process" ifl:type="IntegrationProcess" name="HTTP to SOAP Forwarder Process" processRef="Process_1">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:messageFlow id="MessageFlow_Sender" name="HTTP POST" sourceRef="Participant_Sender" targetRef="StartEvent_1">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>Description</key>
                    <value>Receives HTTP POST request</value>
                </ifl:property>
                <ifl:property>
                    <key>ComponentNS</key>
                    <value>sap</value>
                </ifl:property>
                <ifl:property>
                    <key>componentVersion</key>

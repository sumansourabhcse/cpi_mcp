                </ifl:property>
                <ifl:property>
                    <key>scriptLanguage</key>
                    <value>Groovy</value>
                </ifl:property>
                <ifl:property>
                    <key>scriptBundleID</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>script</key>
                    <value>PrepareSOAPEnvelope.groovy</value>
                </ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_1</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_2</bpmn2:outgoing>
        </bpmn2:scriptTask>
        <bpmn2:callActivity id="ContentModifier_1" name="Set SOAP Headers">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>activityType</key>
                    <value>Enricher</value>
                </ifl:property>
                <ifl:property>
                    <key>componentVersion</key>
                    <value>1.2</value>
                </ifl:property>
                <ifl:property>
                    <key>headerTable</key>
                    <value>&lt;row&gt;&lt;cell&gt;Content-Type&lt;/cell&gt;&lt;cell&gt;text/xml;charset=UTF-8&lt;/cell&gt;&lt;cell&gt;constant&lt;/cell&gt;&lt;cell&gt;false&lt;/cell&gt;&lt;cell&gt;false&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;SOAPAction&lt;/cell&gt;&lt;cell&gt;{{SOAPAction}}&lt;/cell&gt;&lt;cell&gt;constant&lt;/cell&gt;&lt;cell&gt;false&lt;/cell&gt;&lt;cell&gt;false&lt;/cell&gt;&lt;/row&gt;</value>
                </ifl:property>
                <ifl:property>
                    <key>bodyType</key>

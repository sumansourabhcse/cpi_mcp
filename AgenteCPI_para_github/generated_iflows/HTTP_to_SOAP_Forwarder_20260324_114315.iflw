--- SCRIPT: LogErrorDetails.groovy ---
groovy
import com.sap.gateway.ip.core.customdev.util.Message
import java.util.HashMap

def Message processData(Message message) {
    def messageLog = messageLogFactory.getMessageLog(message)
    
    try {
        // Retrieve error information from exchange properties
        def map = message.getProperties()
        def exception = map.get("CamelExceptionCaught")
        
        def errorMessage = "Unknown error occurred"
        def errorDetails = ""
        
        if (exception != null) {
            errorMessage = exception.getMessage() ?: "No error message available"
            errorDetails = exception.getClass().getName() + "\n"
            errorDetails += "Message: " + errorMessage + "\n"
            errorDetails += "Stack Trace:\n" + exception.getStackTrace().collect { it.toString() }.join("\n")
        }
        
        // Log complete error details
        messageLog.addAttachmentAsString("Complete_Error_Details", errorDetails, "text/plain")
        messageLog.setStringProperty("ErrorMessage", errorMessage)
        
        // Build error response JSON
        def errorResponse = [
            status: "error",
            code: 500,
            message: errorMessage,
            timestamp: new Date().format("yyyy-MM-dd'T'HH:mm:ss.SSS'
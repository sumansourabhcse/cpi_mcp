                <di:waypoint x="250" xsi:type="dc:Point" y="166"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="MessageFlow_Out" id="BPMNEdge_MessageFlow_Out">
                <di:waypoint x="1046" xsi:type="dc:Point" y="166"/>
